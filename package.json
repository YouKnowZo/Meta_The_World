{
  "name": "meta-the-world",
  "version": "1.0.0",
  "description": "Hyper-realistic metaverse with virtual real estate and unlimited possibilities",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "install:all": "npm install && cd client && npm install",
    "seed": "node server/scripts/seed.js",
    "seed:products": "node server/scripts/seedProducts.js",
    "seed:cities": "node server/scripts/seedCities.js",
    "seed:quests": "node server/scripts/seedQuests.js",
    "seed:achievements": "node server/scripts/seedAchievements.js",
    "seed:all": "npm run seed:cities && npm run seed:products && npm run seed:quests && npm run seed:achievements"
  },
  "keywords": ["metaverse", "vr", "ar", "nft", "real-estate", "3d"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "mongoose": "^7.6.3",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "ethers": "^6.9.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2"
  }
}
